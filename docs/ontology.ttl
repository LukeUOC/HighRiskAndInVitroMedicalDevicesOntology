:regulatoryFramework rdf:type owl:DatatypeProperty ;
                     rdfs:domain :MedicalDevice ;
                     rdfs:range xsd:string .


###  http://example.org/meddevices#reportDate
:reportDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string .


###  http://example.org/meddevices#riskCategory
:riskCategory rdf:type owl:DatatypeProperty ;
              rdfs:domain :Risk ;
              rdfs:range xsd:string .


###  http://example.org/meddevices#riskDescription
:riskDescription rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range xsd:string .


###  http://example.org/meddevices#riskName
:riskName rdf:type owl:DatatypeProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string .


