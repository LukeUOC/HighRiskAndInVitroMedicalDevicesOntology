@prefix : <http://example.org/meddevices#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/meddevices#> .

<http://example.org/meddevices#> rdf:type owl:Ontology ;
                                  <http://purl.org/dc/terms/created> "16-04-2026" ;
                                  <http://purl.org/dc/terms/creator> "Luke Eduard Belda de Vial" ;
                                  <http://purl.org/dc/terms/description> "Ontology for high-risk medical devices and also in vitro diagnostic devices based on  EUDAMED data." ;
                                  <http://purl.org/dc/terms/title> "HighRiskAndInVitroMedicalDevicesOntology" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/meddevices#hasFSCA
:hasFSCA rdf:type owl:ObjectProperty ;
         owl:inverseOf :isFSCAForIncident ;
         rdfs:domain :Incident ;
         rdfs:range :FSCA ;
         rdfs:comment "Relates an incident to theFSCA taken in response to it."@en ;
         rdfs:label "has FSCA"@en .


###  http://example.org/meddevices#hasIncident
:hasIncident rdf:type owl:ObjectProperty ;
             owl:inverseOf :isIncidentOf ;
             rdfs:domain :MedicalDevice ;
             rdfs:range :Incident ;
             rdfs:comment "Relates the medical device to an incident."@en ;
             rdfs:label "has incident"@en .


###  http://example.org/meddevices#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 owl:inverseOf :manufactures ;
                 rdfs:domain :MedicalDevice ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Relates a medical device to the manufacturer"@en ;
                 rdfs:label "has manufacturer"@en .


###  http://example.org/meddevices#involvesRisk
:involvesRisk rdf:type owl:ObjectProperty ;
              rdfs:domain :Incident ;
              rdfs:range :Risk ;
              rdfs:comment "Relates an incident to the risk."@en ;
              rdfs:label "involves risk"@en .


###  http://example.org/meddevices#isAffectedByFSCA
:isAffectedByFSCA rdf:type owl:ObjectProperty ;
                  rdfs:domain :MedicalDevice .


###  http://example.org/meddevices#isFSCAForIncident
:isFSCAForIncident rdf:type owl:ObjectProperty ;
                   rdfs:domain :FSCA ;
                   rdfs:range :Incident ;
                   rdfs:comment "Relates a FSCA to the incident."@en ;
                   rdfs:label "is FSCA for incident"@en .


###  http://example.org/meddevices#isIncidentOf
:isIncidentOf rdf:type owl:ObjectProperty ;
              rdfs:domain :Incident ;
              rdfs:range :MedicalDevice ;
              rdfs:comment "Relates the incident to the medical device."@en ;
              rdfs:label "is incident of"@en .


###  http://example.org/meddevices#manufactures
:manufactures rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range :MedicalDevice ;
              rdfs:comment "Relates a manufacturer to a medical device that it produces."@en ;
              rdfs:label "manufactures"@en .


###  http://example.org/meddevices#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Relates an incident to the manufacturer that reported it."@en ;
            rdfs:label "reported by"@en .


#################################################################
#    Data properties
#################################################################

###  http://example.org/meddevices#actionDate
:actionDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :FSCA ;
            rdfs:range xsd:string .


###  http://example.org/meddevices#affectedDeviceType
:affectedDeviceType rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range xsd:string .


###  http://example.org/meddevices#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string .


###  http://example.org/meddevices#closureDate
:closureDate rdf:type owl:DatatypeProperty ;
             rdfs:domain :FSCA ;
             rdfs:range xsd:string .


###  http://example.org/meddevices#competentAuthority
:competentAuthority rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Manufacturer ;
                    rdfs:range xsd:string .


###  http://example.org/meddevices#contactEmail
:contactEmail rdf:type owl:DatatypeProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string .


###  http://example.org/meddevices#correctiveActionTaken
:correctiveActionTaken rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:boolean .


###  http://example.org/meddevices#countriesAffected
:countriesAffected rdf:type owl:DatatypeProperty ;
                   rdfs:domain :FSCA ;
                   rdfs:range xsd:string .


###  http://example.org/meddevices#country
:country rdf:type owl:DatatypeProperty ;
         rdfs:domain :Manufacturer ;
         rdfs:range xsd:string .


###  http://example.org/meddevices#countryReported
:countryReported rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range xsd:string .


###  http://example.org/meddevices#description
:description rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string .


###  http://example.org/meddevices#detectionDate
:detectionDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:string .


###  http://example.org/meddevices#deviceName
:deviceName rdf:type owl:DatatypeProperty ;
            rdfs:domain :MedicalDevice ;
            rdfs:range xsd:string .


###  http://example.org/meddevices#devicesAffectedCount
:devicesAffectedCount rdf:type owl:DatatypeProperty ;
                      rdfs:domain :FSCA ;
                      rdfs:range xsd:integer .


###  http://example.org/meddevices#eudamedFSCARef
:eudamedFSCARef rdf:type owl:DatatypeProperty ;
                rdfs:domain :FSCA ;
                rdfs:range xsd:string .


###  http://example.org/meddevices#eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string .


###  http://example.org/meddevices#eudamedSRN
:eudamedSRN rdf:type owl:DatatypeProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string .


###  http://example.org/meddevices#eventDate
:eventDate rdf:type owl:DatatypeProperty ;
           rdfs:domain :Incident ;
           rdfs:range xsd:string .


###  http://example.org/meddevices#fscaDescription
:fscaDescription rdf:type owl:DatatypeProperty ;
                 rdfs:domain :FSCA ;
                 rdfs:range xsd:string .


###  http://example.org/meddevices#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string .


###  http://example.org/meddevices#incidentDescription
:incidentDescription rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range xsd:string .


###  http://example.org/meddevices#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ;
                 rdfs:domain :MedicalDevice ;
                 rdfs:range xsd:string .


###  http://example.org/meddevices#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:boolean .


###  http://example.org/meddevices#isIVD
:isIVD rdf:type owl:DatatypeProperty ;
       rdfs:domain :MedicalDevice ;
