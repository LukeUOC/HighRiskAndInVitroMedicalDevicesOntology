#################################################################
#    Classes
#################################################################

###  http://example.org/meddevices#ClassI
:ClassI rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        owl:disjointWith :ClassIII ,
                         :ClassIIa ,
                         :ClassIIb .


###  http://example.org/meddevices#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          owl:disjointWith :ClassIIa ,
                           :ClassIIb .


###  http://example.org/meddevices#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          owl:disjointWith :ClassIIb .


###  http://example.org/meddevices#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  http://example.org/meddevices#FSCA
:FSCA rdf:type owl:Class ;
      rdfs:subClassOf :MedicalEntity ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :isFSCAForIncident ;
                        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :Incident
                      ] ;
      rdfs:comment "Field safety corrective action taken as a response to a reported incident."@en ;
      rdfs:label "Field safety corrective action"@en .


###  http://example.org/meddevices#HighRiskMedicalDevice
:HighRiskMedicalDevice rdf:type owl:Class ;
                       rdfs:subClassOf :MedicalDevice ;
                       rdfs:comment "Device classified as high risk."@en ;
                       rdfs:label "High-risk medical device"@en .


###  http://example.org/meddevices#IVDClassA
:IVDClassA rdf:type owl:Class ;
           rdfs:subClassOf :InVitroDiagnosticDevice ;
           owl:disjointWith :IVDClassB ,
                            :IVDClassC ,
                            :IVDClassD .


###  http://example.org/meddevices#IVDClassB
:IVDClassB rdf:type owl:Class ;
           rdfs:subClassOf :InVitroDiagnosticDevice ;
           owl:disjointWith :IVDClassC ,
                            :IVDClassD .


###  http://example.org/meddevices#IVDClassC
:IVDClassC rdf:type owl:Class ;
           rdfs:subClassOf :InVitroDiagnosticDevice ;
           owl:disjointWith :IVDClassD .


###  http://example.org/meddevices#IVDClassD
:IVDClassD rdf:type owl:Class ;
           rdfs:subClassOf :InVitroDiagnosticDevice .


###  http://example.org/meddevices#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :FSCA ;
                  owl:disjointWith :Recall ,
                                   :SafetyAlert ,
                                   :UserNotice .


###  http://example.org/meddevices#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :MedicalDevice ;
                         rdfs:comment "Device made for in vitro diagnostic use."@en ;
                         rdfs:label "In vitro diagnostic device"@en .


###  http://example.org/meddevices#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf :MedicalEntity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :involvesRisk ;
                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Risk
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isIncidentOf ;
                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :MedicalDevice
                          ] ;
          rdfs:comment "Reported incident linked to a medical device." ;
          rdfs:label "Incident"@en .


###  http://example.org/meddevices#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf :MedicalEntity ;
              rdfs:comment "Organization responsible for producing the medical device."@en ;
              rdfs:label "Manufacturer"@en .


###  http://example.org/meddevices#MedicalDevice
:MedicalDevice rdf:type owl:Class ;
               rdfs:subClassOf :MedicalEntity ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasManufacturer ;
                                 owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :Manufacturer
                               ] ;
               rdfs:comment "Device in the catalogue, includes high-risk devices and in vitro diagnostic devices."@en ;
               rdfs:label "Medical device"@en .


###  http://example.org/meddevices#MedicalEntity
:MedicalEntity rdf:type owl:Class ;
               rdfs:comment "Class that contains all the main entities represented in the ontology."@en ;
               rdfs:label "Medical entity"@en .


###  http://example.org/meddevices#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  owl:disjointWith :SeriousIncident .


###  http://example.org/meddevices#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :FSCA ;
        owl:disjointWith :SafetyAlert ,
                         :UserNotice .


###  http://example.org/meddevices#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf :MedicalEntity ;
      rdfs:comment "Risk identified for a medical device." ;
      rdfs:label "Risk"@en .


###  http://example.org/meddevices#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:subClassOf :MedicalEntity ;
           rdfs:comment "A risk classification used to classify medical devices according to their risk level."@en ;
           rdfs:label "Risk class"@en .


###  http://example.org/meddevices#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :FSCA ;
             owl:disjointWith :UserNotice .


###  http://example.org/meddevices#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident .


###  http://example.org/meddevices#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :FSCA .


#################################################################
#    Individuals
#################################################################

###  http://example.org/meddevices#DEV-001
:DEV-001 rdf:type owl:NamedIndividual ;
         :hasManufacturer :MAN-001 ;
         :deviceName "HeartMate 3 LVAD" ;
         :intendedPurpose "Ventricular assist device for end-stage heart failure" ;
         :isActive "true"^^xsd:boolean ;
         :isIVD "false"^^xsd:boolean ;
         :isImplantable "true"^^xsd:boolean ;
         :isReusable "false"^^xsd:boolean ;
         :regulatoryFramework "MDR" ;
         :udiDI "(01)00380740009095" .


###  http://example.org/meddevices#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   :SafetyAlert ;
          :isFSCAForIncident :INC-001 ;
          :actionDate "2024-02-01" ;
          :countriesAffected "EU-wide" ;
          :devicesAffectedCount 850 ;
          :eudamedFSCARef "EU-FSCA-2024-000001" ;
          :fscaDescription "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          :scope "All HeartMate 3 LVAD units implanted since 2020" ;
          :status "Open" .


###  http://example.org/meddevices#INC-001
:INC-001 rdf:type owl:NamedIndividual ,
                  :SeriousIncident ;
         :involvesRisk :RSK-003 ;
         :isIncidentOf :DEV-001 ;
         :correctiveActionTaken "true"^^xsd:boolean ;
         :countryReported "Germany" ;
         :description "Patient implanted with HeartMate 3 LVAD developed ischemic stroke 6 months post-implant. Device thrombus confirmed by echocardiography." ;
         :detectionDate "2024-01-10" ;
         :eudamedIncidentRef "EU-INC-2024-000001" ;
         :eventDate "2024-01-08" ;
         :outcome "Serious patient injury - embolic stroke" ;
         :patientAge 58 ;
         :patientSex "Male" ;
         :reportDate "2024-01-15" .


###  http://example.org/meddevices#MAN-001
:MAN-001 rdf:type owl:NamedIndividual ,
                  :Manufacturer ;
         :authorizationNumber "IE/2017/001234" ;
         :contactEmail "regulatory@medtronic.com" ;
         :country "Ireland" ;
         :eudamedSRN "SRN-IE-MED-0001" ;
         <http://www.w3.org/2006/vcard/ns#organization-name> "Medtronic plc" .


###  http://example.org/meddevices#RSK-003
:RSK-003 rdf:type owl:NamedIndividual ,
                  :Risk ;
         :affectedDeviceType "ImplantableActiveDevice" ;
         :imdrfCode "A0201" ;
         :probability "Low" ;
         :riskCategory "Patient Harm" ;
         :riskDescription "Thrombus formation on device surface causing embolic events" ;
         :riskName "Thrombosis - device-related" ;
         :riskType "InjuryRisk" ;
         :severity "Critical" .


#################################################################
#    Rules
#################################################################

:d rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:i rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "R1" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :MedicalDevice ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :d
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasIncident ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :d ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :i
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :isIncidentOf ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :i ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> :d
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

