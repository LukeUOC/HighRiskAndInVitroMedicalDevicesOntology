<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/meddevices#"
     xml:base="http://example.org/meddevices"
     xmlns:ns="http://www.w3.org/2006/vcard/ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:meddevices="http://example.org/meddevices#">
    <owl:Ontology rdf:about="http://example.org/meddevices#">
        <terms:created>16-04-2026</terms:created>
        <terms:creator>Luke Eduard Belda de Vial</terms:creator>
        <terms:description>Ontology for high-risk medical devices and also in vitro diagnostic devices based on  EUDAMED data.</terms:description>
        <terms:title>HighRiskAndInVitroMedicalDevicesOntology</terms:title>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/meddevices#hasFSCA -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevices#hasFSCA">
        <owl:inverseOf rdf:resource="http://example.org/meddevices#isFSCAForIncident"/>
        <rdfs:domain rdf:resource="http://example.org/meddevices#Incident"/>
        <rdfs:range rdf:resource="http://example.org/meddevices#FSCA"/>
        <rdfs:comment xml:lang="en">Relates an incident to theFSCA taken in response to it.</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevices#hasIncident -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevices#hasIncident">
        <owl:inverseOf rdf:resource="http://example.org/meddevices#isIncidentOf"/>
        <rdfs:domain rdf:resource="http://example.org/meddevices#MedicalDevice"/>
        <rdfs:range rdf:resource="http://example.org/meddevices#Incident"/>
        <rdfs:comment xml:lang="en">Relates the medical device to an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">has incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevices#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevices#hasManufacturer">
        <owl:inverseOf rdf:resource="http://example.org/meddevices#manufactures"/>
        <rdfs:domain rdf:resource="http://example.org/meddevices#MedicalDevice"/>
        <rdfs:range rdf:resource="http://example.org/meddevices#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a medical device to the manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevices#involvesRisk -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevices#involvesRisk">
        <rdfs:domain rdf:resource="http://example.org/meddevices#Incident"/>
        <rdfs:range rdf:resource="http://example.org/meddevices#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">involves risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevices#isAffectedByFSCA -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevices#isAffectedByFSCA">
        <rdfs:domain rdf:resource="http://example.org/meddevices#MedicalDevice"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevices#isFSCAForIncident -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevices#isFSCAForIncident">
        <rdfs:domain rdf:resource="http://example.org/meddevices#FSCA"/>
        <rdfs:range rdf:resource="http://example.org/meddevices#Incident"/>
        <rdfs:comment xml:lang="en">Relates a FSCA to the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">is FSCA for incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevices#isIncidentOf -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevices#isIncidentOf">
        <rdfs:domain rdf:resource="http://example.org/meddevices#Incident"/>
        <rdfs:range rdf:resource="http://example.org/meddevices#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Relates the incident to the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">is incident of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevices#manufactures -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevices#manufactures">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://example.org/meddevices#Manufacturer"/>
        <rdfs:range rdf:resource="http://example.org/meddevices#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to a medical device that it produces.</rdfs:comment>
        <rdfs:label xml:lang="en">manufactures</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevices#reportedBy -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevices#reportedBy">
        <rdfs:domain rdf:resource="http://example.org/meddevices#Incident"/>
        <rdfs:range rdf:resource="http://example.org/meddevices#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates an incident to the manufacturer that reported it.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


