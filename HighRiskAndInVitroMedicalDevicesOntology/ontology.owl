    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/meddevices#ClassI -->


    <owl:Class rdf:about="http://example.org/meddevices#ClassI">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevices#RiskClass"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#ClassIII"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#ClassIIa"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#ClassIIb"/>
    </owl:Class>
    


    <!-- http://example.org/meddevices#ClassIII -->


    <owl:Class rdf:about="http://example.org/meddevices#ClassIII">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevices#RiskClass"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#ClassIIa"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#ClassIIb"/>
    </owl:Class>
    


    <!-- http://example.org/meddevices#ClassIIa -->


    <owl:Class rdf:about="http://example.org/meddevices#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevices#RiskClass"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#ClassIIb"/>
    </owl:Class>
    


    <!-- http://example.org/meddevices#ClassIIb -->


    <owl:Class rdf:about="http://example.org/meddevices#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevices#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/meddevices#FSCA -->


    <owl:Class rdf:about="http://example.org/meddevices#FSCA">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevices#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevices#isFSCAForIncident"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/meddevices#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Field safety corrective action taken as a response to a reported incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Field safety corrective action</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevices#HighRiskMedicalDevice -->


    <owl:Class rdf:about="http://example.org/meddevices#HighRiskMedicalDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevices#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Device classified as high risk.</rdfs:comment>
        <rdfs:label xml:lang="en">High-risk medical device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevices#IVDClassA -->


    <owl:Class rdf:about="http://example.org/meddevices#IVDClassA">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevices#InVitroDiagnosticDevice"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#IVDClassB"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#IVDClassC"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#IVDClassD"/>
    </owl:Class>
    


    <!-- http://example.org/meddevices#IVDClassB -->


    <owl:Class rdf:about="http://example.org/meddevices#IVDClassB">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevices#InVitroDiagnosticDevice"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#IVDClassC"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#IVDClassD"/>
    </owl:Class>
    


    <!-- http://example.org/meddevices#IVDClassC -->


    <owl:Class rdf:about="http://example.org/meddevices#IVDClassC">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevices#InVitroDiagnosticDevice"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevices#IVDClassD"/>
    </owl:Class>
    


    <!-- http://example.org/meddevices#IVDClassD -->


